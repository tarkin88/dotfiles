set $gaps 5
set $font xft:JetBrains Mono 11
set $lock_time 30

# - keys -
set $mod Mod4
set $alt Mod1
set $ctrl Ctrl

# - apps -
set $terminal urxvt
set $browser google-chrome-stable
set $rofi ~/.local/bin/rofi-launcher
set $screenie ~/.local/bin/screenie
set $media-manager ~/.local/bin/media-manager
set $lock ~/.local/bin/lock

include ~/.i3/conf.d/*.conf

default_border pixel 3
default_floating_border normal
smart_borders on
hide_edge_borders none
focus_follows_mouse yes
floating_modifier $mod
title_align center 
