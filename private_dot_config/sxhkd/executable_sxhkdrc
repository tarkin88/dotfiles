#
# wm independent hotkeys
#

# spawn terminal emulator
super + Return
	st
# spawn a floating terminal
super + shift + Return
	st -c floating

# program launcher
super + p
  rofi -show drun
# command launcher
super + shift + p
  rofi -show run

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

# Lockscreen
ctrl + alt + l
    betterlockscreen -l dimblur

# Clipboard manager
ctrl + alt + h
    ~/.local/bin/clipboard-menu

# Powermenu
ctrl + alt + x
    ~/.local/bin/power-menu

# Screenshots menu
Print
    ~/.local/bin/screenshots-menu -m

# keyboard layout switcher
ctrl + alt + @space
    ~/.local/bin/keyboard-swithcer-menu

# Favorites files and directories
ctrl + alt + e
    ~/.local/bin/favorites-menu

# Favorites apps
ctrl + alt + p
    ~/.local/bin/favorites-apps-menu

# utils menu
ctrl + alt + u
    ~/.local/bin/utils-menu

# this help
super + F1
    ~/.local/bin/sxhkd-help-menu
# powersave mode
super + F2
    ~/.local/bin/powersave-menu

# gotop
ctrl + alt + Escape
  st -c floating -g 142x39+0+0 -e gotop


# quit/restart bspwm
super + alt + {q,r}
	bspc {quit,wm -r}

# close and kill
super + shift + c
	bspc node -c
	# bspc node -{c,k}

# alternate between the tiled and monocle layout
super + m
	bspc desktop -l next

# send the newest marked node to the newest preselected node
super + y
	bspc node newest.marked.local -n newest.!automatic.local

# swap the current node and the biggest window
super + g
	bspc node -s biggest.window

#
# state/flags
#

# set the window state
super + {t,shift + t,s,f}
	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}

# set the node flags
super + ctrl + {m,x,y,z}
	bspc node -g {marked,locked,sticky,private}

#
# focus/swap
#

# focus the node in the given direction
super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

# focus the node for the given path jump
super + {p,b,comma,period}
	bspc node -f @{parent,brother,first,second}

# focus the next/previous window in the current desktop
super + {_,shift + }@space
	bspc node -f {next,prev}.local.!hidden.window

# focus the next/previous desktop in the current monitor
super + bracket{left,right}
	bspc desktop -f {prev,next}.local

# focus the last node/desktop
super + {grave,Tab}
	bspc {node,desktop} -f last

# focus the older or newer node in the focus history
super + {o,i}
	bspc wm -h off; \
	bspc node {older,newer} -f; \
	bspc wm -h on

# focus or send to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'

#
# preselect
#

# preselect the direction
super + ctrl + {h,j,k,l}
	bspc node -p {west,south,north,east}

# preselect the ratio
super + ctrl + {1-9}
	bspc node -o 0.{1-9}

# cancel the preselection for the focused node
super + ctrl + space
	bspc node -p cancel

# cancel the preselection for the focused desktop
super + ctrl + shift + space
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

#
# move/resize
#

# expand a window by moving one of its side outward
super + alt + {h,j,k,l}
	bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# contract a window by moving one of its side inward
super + alt + shift + {h,j,k,l}
	bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

# move a floating window
super + {Left,Down,Up,Right}
	bspc node -v {-20 0,0 20,0 -20,20 0}


# Toggle scratchpad 1
super + w
    bspwm-toggle-visibility  scratchpad-one  "st -c scratchpad-one -g 100x39+1+50"

# Toggle scratchpad 2
super + e
    bspwm-toggle-visibility  scratchpad-two  "st -c scratchpad-two -g 100x39-10+50"

# Toggle scratchpad 2
super + u
    bspwm-toggle-visibility  scratchpad-three  "st -c scratchpad-three -g 120x29+0+0"
# Toggle scratchpad files
super + r
    bspwm-toggle-visibility  scratchpad-files  "st -c scratchpad-files -g 85x18+0+0 ranger"

# Toggle scratchpad volume
super + v
    bspwm-toggle-visibility  scratchpad-volume  "st -c scratchpad-volume -g 75x9+0+0 pulsemixer"

# scratch notes
ctrl + alt + t
  ~/.local/bin/scratchpad-notes

# Up/Down volume
XF86Audio{RaiseVolume,LowerVolume}
	pulsemixer --change-volume {+5,-5}

# Toggle volume mute
XF86AudioMute
  pulsemixer --toggle-mute

# Music control
XF86Audio{Next,Prev,Play,Stop}
	playerctl {next,previous,play-pause,stop}

# Brighness control
XF86MonBrightness{Up,Down}
	brightnessctl s {+5%,5%-}
