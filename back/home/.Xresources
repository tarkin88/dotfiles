! X colors.
! Generated by 'wal'
*foreground:        #c8bdaf
*background:        #0B1713
*.foreground:       #c8bdaf
*.background:       #0B1713
emacs*foreground:   #c8bdaf
emacs*background:   #0B1713
URxvt*foreground:   #c8bdaf
XTerm*foreground:   #c8bdaf
UXTerm*foreground:  #c8bdaf
URxvt*background:   [100]#0B1713
XTerm*background:   #0B1713
UXTerm*background:  #0B1713
URxvt*cursorColor:  #c8bdaf
XTerm*cursorColor:  #c8bdaf
UXTerm*cursorColor: #c8bdaf
URxvt*borderColor:  [100]#0B1713

! Colors 0-15.
*.color0: #0B1713
*color0:  #0B1713
*.color1: #3A4242
*color1:  #3A4242
*.color2: #514F47
*color2:  #514F47
*.color3: #6F5F50
*color3:  #6F5F50
*.color4: #8F3A50
*color4:  #8F3A50
*.color5: #8D705C
*color5:  #8D705C
*.color6: #7C8171
*color6:  #7C8171
*.color7: #c8bdaf
*color7:  #c8bdaf
*.color8: #8c847a
*color8:  #8c847a
*.color9: #3A4242
*color9:  #3A4242
*.color10: #514F47
*color10:  #514F47
*.color11: #6F5F50
*color11:  #6F5F50
*.color12: #8F3A50
*color12:  #8F3A50
*.color13: #8D705C
*color13:  #8D705C
*.color14: #7C8171
*color14:  #7C8171
*.color15: #c8bdaf
*color15:  #c8bdaf

! Black color that will not be affected by bold highlighting.
*.color66: #0B1713
*color66:  #0B1713

! Xclock colors.
XClock*foreground: #c8bdaf
XClock*background: #0B1713
XClock*majorColor:  rgba:c8/bd/af/ff
XClock*minorColor:  rgba:c8/bd/af/ff
XClock*hourColor:   rgba:c8/bd/af/ff
XClock*minuteColor: rgba:c8/bd/af/ff
XClock*secondColor: rgba:c8/bd/af/ff

! Set depth to make transparency work.
URxvt*depth: 32
Xft.dpi: 130
