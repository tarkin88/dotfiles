[global]
monitor = 0
origin = top-center
follow = mouse
#geometry = "380x50-10+38"
width = 470
height = (100,400)
offset = (10, 20)
indicate_hidden = yes
shrink = no
separator_height = 4
separator_color = auto
padding = 20
horizontal_padding = 20
frame_width = 2
ellipsize = middle
sort = no
idle_threshold = 120
font = JetBrainsMono Nerd Font 11
line_height = 4
markup = full
format = %s\n%b
alignment = left
show_age_threshold = 60
word_wrap = yes
ignore_newline = no
stack_duplicates = false
hide_duplicate_count = yes
show_indicators = yes
icon_position = left
max_icon_size = 48
sticky_history = yes
history_length = 20
browser = x-www-browser -new-tab
mouse_left_click = do_action
mouse_middle_click = close_all
mouse_right_click = close_current
always_run_script = true
title = Dunst
class = Dunst
separator_color = auto
frame_color = "#ffd866"

[Spotify]
    appname=Spotify
    format = "<b>  %s</b>\n%b"
    frame_color = "#79eaa2"


[Tooler]
  appname=Tooler
  frame_color="#80e7db"


[urgency_low]
timeout = 3
background = "#282828"
foreground = "#C4C7C5"

[urgency_normal]
timeout = 5
background = "#282828"
foreground = "#C4C7C5"

[urgency_critical]
timeout = 0
background = "#282828"
foreground = "#EC407A"
frame_color = "#EC407A"
